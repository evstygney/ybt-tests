{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PSYvIT Exercise Config",
  "type": "object",
  "required": [
    "id",
    "slug",
    "title",
    "goal",
    "week",
    "target_skill",
    "ybt_focus",
    "duration_min",
    "mode",
    "badge",
    "level",
    "summary",
    "steps",
    "content",
    "scoring",
    "feedback_rules",
    "reflection_prompt",
    "admin_editable_fields",
    "recommendation_48h",
    "micro_experiment_prompt",
    "week_theme"
  ],
  "properties": {
    "id": { "type": "string" },
    "slug": { "type": "string" },
    "title": { "type": "string" },
    "goal": { "type": "string" },
    "week": { "type": "integer" },
    "target_skill": { "type": "string" },
    "ybt_focus": {
      "type": "array",
      "items": { "enum": ["Я", "Бизнес", "Команда"] },
      "minItems": 1
    },
    "duration_min": { "type": "integer" },
    "mode": { "type": "string" },
    "badge": { "type": "string" },
    "level": { "type": "string" },
    "summary": { "type": "string" },
    "steps": { "type": "array", "minItems": 1 },
    "content": { "type": "object" },
    "scoring": {
      "type": "object",
      "required": ["base_points", "bonus_points", "penalty_points"]
    },
    "feedback_rules": { "type": "array" },
    "reflection_prompt": { "type": "string" },
    "admin_editable_fields": { "type": "array" },
    "recommendation_48h": { "type": "string" },
    "micro_experiment_prompt": { "type": "string" },
    "week_theme": { "type": "string" }
  }
}
